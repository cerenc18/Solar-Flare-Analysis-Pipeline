   "source": [
    "# Final formatting and sizing configuration \n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from datetime import datetime\n",
    "from scipy.signal import savgol_filter\n",
    "from scipy.interpolate import interp1d\n",
    "from astropy.io import fits\n",
    "import os\n",
    "from PIL import Image\n",
    "from reportlab.pdfgen import canvas\n",
    "from reportlab.lib.pagesizes import letter\n",
    "\n",
    "# File paths\n",
    "file_path = r'C:\\Data\\Project\\outputs\\guncel_new.txt'\n",
    "lat_dir = r'C:\\Data\\Project\\outputs\\indirilen_fits_LAT'\n",
    "gbm_dir = r'C:\\Data\\Project\\outputs\\indirilen_fits3'\n",
    "goes_dir = r'C:\\Data\\Project\\outputs\\indirilen_fits_GOES'\n",
    "plot_dir = r'C:\\Data\\Project\\outputs\\combined_plots'\n",
    "os.makedirs(plot_dir, exist_ok=True)\n",
    "\n",
    "df = pd.read_csv(file_path, sep='\\t')\n",
    "\n",
    "\n",
    "\n",
    "# Convert date formats\n",
    "def convert_date(date_str):\n",
    "    try:\n",
    "        formats = [\"%d-%b-%Y\", \"%d.%m.%Y\"]\n",
    "        for fmt in formats:\n",
    "            try:\n",
    "                return datetime.strptime(date_str, fmt).strftime(\"%Y-%m-%d\")\n",
    "            except ValueError:\n",
    "                continue\n",
    "        raise ValueError(f\"Date format not recognized: {date_str}\")\n",
    "    except Exception as e:\n",
    "        print(f\"Error converting date: {e}\")\n",
    "        return None\n",
    "# Light curve plotting function for GBM\n",
    "def plot_light_curve_gbm(\n",
    "    ax, \n",
    "    file_path,\n",
    "    start_time,\n",
    "    end_time,\n",
    "    peak_time,\n",
    "    detector,\n",
    "    start_time_str,\n",
    "    end_time_str,\n",
    "    bin_size=2.0,\n",
    "    time_unit='hour'  # 'hour' or 'second'\n",
    "):\n",
    "    \"\"\"\n",
    "    Plots Fermi/GBM light curve.\n",
    "    time_unit='hour' -> x-axis in hours\n",
    "    time_unit='second' -> x-axis in seconds\n",
    "    \"\"\"\n",
    "\n",
    "    try:\n",
    "        with fits.open(file_path, ignore_missing_simple=True) as hdul:\n",
    "            # Read energy ranges\n",
    "            data_en = hdul[1].data\n",
    "            e_min = np.round(data_en['E_MIN']).astype(int)\n",
    "            e_max = np.round(data_en['E_MAX']).astype(int)\n",
    "\n",
    "            # Light curve data\n",
    "            data = hdul[2].data\n",
    "            header_gbm = hdul[2].header\n",
    "\n",
    "            tstart = float(header_gbm.get('TSTART', 0))\n",
    "            trigtime = float(header_gbm.get('TRIGTIME', 0))\n",
    "\n",
    "            counts = data['COUNTS']\n",
    "            time = data['TIME']\n",
    "            exposure = data['EXPOSURE']\n",
    "\n",
    "            # Time alignment — reset all data relative to trigtime\n",
    "            time = time + tstart - trigtime\n",
    "\n",
    "            # If data duration > 25 hours, normalize it (occurs in some GBM files)\n",
    "            if max(time) / 3600.0 > 25.5:\n",
    "                time = time - min(time)\n",
    "\n",
    "            # Correct faulty or zero exposure\n",
    "            exposure = np.where(exposure == 0, np.nan, exposure)\n",
    "            normalized_counts = np.divide(counts, exposure[:, np.newaxis])\n",
    "\n",
    "            # Binning\n",
    "            bin_edges = np.arange(time[0], time[-1] + bin_size, bin_size)\n",
    "            binned_counts = np.zeros((len(bin_edges) - 1, counts.shape[1])) * np.nan\n",
    "\n",
    "            for i in range(len(bin_edges) - 1):\n",
    "                in_bin = (time >= bin_edges[i]) & (time < bin_edges[i + 1])\n",
    "                if np.any(in_bin):\n",
    "                    binned_counts[i, :] = np.nanmean(normalized_counts[in_bin, :], axis=0)\n",
    "\n",
    "            # Convert X-axis to hours or seconds\n",
    "            if time_unit == 'hour':\n",
    "                x_vals = (bin_edges[:-1] + bin_size / 2) / 3600.0\n",
    "                xmin = (start_time - 3600) / 3600.0\n",
    "                xmax = (end_time + 3600) / 3600.0\n",
    "                peak_time_val = peak_time / 3600.0\n",
    "                #x_label = \"Time (hours since trigger)\"\n",
    "            else:\n",
    "                x_vals = bin_edges[:-1] + bin_size / 2\n",
    "                xmin = start_time - 3600\n",
    "                xmax = end_time + 3600\n",
    "                peak_time_val = peak_time\n",
    "                #x_label = \"Time (s since trigger)\"\n",
    "\n",
    "            # Plot the graph\n",
    "            for i in range(len(e_min)):\n",
    "                ax.plot(x_vals, binned_counts[:, i],\n",
    "                        label=f'Counts ({e_min[i]}-{e_max[i]} keV)',\n",
    "                        linewidth=1.8)\n",
    "\n",
    "            ax.set_ylabel('Rates (s$^{-1}$)')\n",
    "            #ax.set_xlabel(x_label)\n",
    "            ax.set_yscale('log')\n",
    "            ax.grid(True, alpha=0.3)\n",
    "\n",
    "            # Time limits\n",
    "            ax.set_xlim(xmin, xmax)\n",
    "            ax.axvline(peak_time_val, color='r', linestyle='--', label='Peak Time')\n",
    "\n",
    "            # Title and annotations\n",
    "            ax.legend(title=f'Fermi/GBM ({detector})', loc='upper right', fontsize=16)\n",
    "            ax.text(0.02, 0.95,\n",
    "                    f'Start: {start_time_str}\\nEnd: {end_time_str}',\n",
    "                    transform=ax.transAxes,\n",
    "                    verticalalignment='top',\n",
    "                    fontsize=18,\n",
    "                    bbox=dict(boxstyle=\"round\", alpha=0.1))\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"Error: {e}\")\n",
    "\n",
    "\n",
    "def plot_light_curve_goes(ax, fits_file_path, start_time, end_time, peak_time, start_time_str, end_time_str):\n",
    "    try:\n",
    "        with fits.open(fits_file_path) as hdul:\n",
    "            data = hdul[2].data\n",
    "\n",
    "            flux = np.array(data['FLUX'])\n",
    "            time = np.array(data['TIME'])\n",
    "\n",
    "            time = np.array(time).reshape(-1)\n",
    "            flux = np.array(flux).reshape(-1, 2) if flux.shape[-1] == 2 else np.array(flux).reshape(-1)\n",
    "\n",
    "            time_hours = time / 3600.0\n",
    "\n",
    "            flux_1 = flux[:, 0]\n",
    "            flux_2 = flux[:, 1]\n",
    "\n",
    "            # --- Left axis (flux values) ---\n",
    "            ax.plot(time_hours, flux_1, color='red', label=\"GOES 1.0–8.0 Å\")\n",
    "            ax.plot(time_hours, flux_2, color='blue', label=\"GOES 0.5–4.0 Å\")\n",
    "            ax.set_ylabel(\"Flux [Watts m$^{-2}$]\")\n",
    "            ax.set_yscale('log')\n",
    "            ax.legend(loc='upper right')\n",
    "\n",
    "            ax.axvline(peak_time / 3600.0, color='r', linestyle='--', label='GOES Peak')\n",
    "            ax.text(0.02, 0.95, f'Start: {start_time_str}\\nEnd: {end_time_str}',\n",
    "                    transform=ax.transAxes, verticalalignment='top',\n",
    "                    bbox=dict(boxstyle=\"round\", alpha=0.1))\n",
    "            ax.grid(True, alpha=0.3)\n",
    "\n",
    "            # --- Right axis (class labels) ---\n",
    "            ax2 = ax.twinx()\n",
    "            ax2.set_yscale('log')\n",
    "            ax2.set_ylim(ax.get_ylim())  # maintain the same log scale\n",
    "\n",
    "            # Class boundaries and labels\n",
    "            class_positions = [1e-8, 1e-7, 1e-6, 1e-5, 1e-4]  # A, B, C, M, X thresholds\n",
    "            class_labels = ['A', 'B', 'C', 'M', 'X']\n",
    "\n",
    "            # Apply these values to the axis\n",
    "            ax2.set_yticks(class_positions)\n",
    "            ax2.set_yticklabels(class_labels)\n",
    "\n",
    "            # Visual guide lines (optional but aesthetically pleasing)\n",
    "            for boundary in class_positions:\n",
    "                ax.axhline(boundary, color='gray', linestyle='--', alpha=0.2)\n",
    "\n",
    "            # Right axis label\n",
    "            ax2.set_ylabel(\"Flare Class\")\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"Error plotting light curve: {e}\")\n",
    "\n",
    "def plot_light_curve_derivative(ax, fits_file_path, start_time, end_time, peak_time, start_time_str, end_time_str):\n",
    "    try:\n",
    "        with fits.open(fits_file_path) as hdul:\n",
    "            data = hdul[2].data\n",
    "\n",
    "            flux = np.array(data['FLUX'])\n",
    "            time = np.array(data['TIME'])\n",
    "            new_time = time - min(time)\n",
    "\n",
    "            time = np.array(time).reshape(-1)\n",
    "            flux = np.array(flux).reshape(-1, 2) if flux.shape[-1] == 2 else np.array(flux).reshape(-1)\n",
    "\n",
    "            time_hours = time / 3600.0\n",
    "\n",
    "            flux_1 = flux[:, 0]\n",
    "            flux_2 = flux[:, 1]\n",
    "            flux_1_deriv = np.gradient(flux_1, time)\n",
    "            flux_2_deriv = np.gradient(flux_2, time)\n",
    "            # Normalize derivatives (to avoid extremely small values)\n",
    "            flux_1_deriv = flux_1_deriv / np.nanmax(np.abs(flux_1_deriv))\n",
    "            flux_2_deriv = flux_2_deriv / np.nanmax(np.abs(flux_2_deriv))\n",
    "\n",
    "            ax.plot(time_hours, flux_1_deriv, color='red', label=\"GOES 1.0-8.0 Å Derivative\")\n",
    "            ax.plot(time_hours, flux_2_deriv, color='blue', label=\"GOES 0.5-4.0 Å Derivative\")\n",
    "            #ax.set_ylabel(\"Derivative of Flux [Watts m$^{-2}$]\")\n",
    "            ax.ticklabel_format(style='plain', axis='y', useOffset=False)\n",
    "            ax.set_ylim(-1.2, 1.2)\n",
    "            ax.set_yscale('linear')\n",
    "\n",
    "            ax.set_ylabel(\"Normalized dFlux/dt [Watts m$^{-2}$]\")\n",
    "\n",
    "            \n",
    "            ax.legend()\n",
    "\n",
    "            ax.axvline(peak_time / 3600.0, color='r', linestyle='--', label='GOES Peak')\n",
    "            ax.text(0.02, 0.95, f'Start: {start_time_str}\\nEnd: {end_time_str}', transform=ax.transAxes,\n",
    "                    verticalalignment='top', bbox=dict(boxstyle=\"round\", alpha=0.1))\n",
    "\n",
    "            ax.grid(True)\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"Error plotting light curve: {e}\")\n",
    "\n",
    "def plot_light_curve_lat(ax, file_path, start_time, end_time, peak_time, start_time_str, end_time_str):\n",
    "    try:\n",
    "        with fits.open(file_path, ignore_missing_simple=True) as hdul:\n",
    "            data = hdul[1].data\n",
    "            header_lat = hdul[1].header\n",
    "\n",
    "            time = data['TIME']\n",
    "            flux = data['COUNTS']\n",
    "\n",
    "            exposure = header_lat['EXPOSURE']\n",
    "            flux = flux / exposure\n",
    "\n",
    "            # Binning to 1-second time resolution\n",
    "            min_time = np.floor(time.min())\n",
    "            max_time = np.ceil(time.max())\n",
    "            binned_time = np.arange(min_time, max_time, 1)\n",
    "            binned_counts = np.zeros_like(binned_time)\n",
    "\n",
    "            for i in range(len(binned_time)):\n",
    "                mask = (time >= binned_time[i]) & (time < binned_time[i] + 1)\n",
    "                binned_counts[i] = flux[mask].sum()\n",
    "\n",
    "            # Convert time to hours\n",
    "            binned_time_hours = (binned_time - min_time) / 3600.0\n",
    "\n",
    "            # Plotting\n",
    "            ax.scatter(binned_time_hours, binned_counts, label=\"Counts > 100 MeV\")\n",
    "            ax.set_xlabel(\"Time (hours)\")\n",
    "            ax.set_ylabel(\"Counts (cm$^{-2}$ s$^{-1}$)\")\n",
    "            ax.set_yscale('log')  # Set Y-axis to logarithmic scale\n",
    "\n",
    "            # Expand Y-axis limits\n",
    "            ymin = max(binned_counts.min() / 2, 1e-10)  # Smallest positive value for log scale\n",
    "            ymax = binned_counts.max() * 2\n",
    "            ax.set_ylim(ymin, ymax)\n",
    "\n",
    "            ax.legend()\n",
    "            # Mark GOES peak\n",
    "            #ax.axvline(peak_time / 3600.0, color='r', linestyle='--', label='GOES Peak')\n",
    "            ax.text(0.02, 0.95, f'Start: {start_time_str}\\nEnd: {end_time_str}', transform=ax.transAxes,\n",
    "                    verticalalignment='top', bbox=dict(boxstyle=\"round\", alpha=0.1))\n",
    "\n",
    "            # Add legend\n",
    "            handles, labels = ax.get_legend_handles_labels()\n",
    "            peak_label = plt.Line2D([], [], color='r', linestyle='--', label='GOES Peak')\n",
    "            handles.append(peak_label)\n",
    "            ax.legend(handles=handles, title='LAT', loc='upper right')\n",
    "\n",
    "            ax.grid(True)\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"Error plotting LAT light curve: {e}\")\n",
    "\n",
    "# Iterate over each row in the dataframe\n",
    "#for index, row in df.iterrows():\n",
    "#for index, row in df.head(1).iterrows():\n",
    "\n",
    "# --- PLOT ONLY SPECIFIC EVENT ---\n",
    "\n",
    "import os\n",
    "from PIL import Image\n",
    "from reportlab.pdfgen import canvas\n",
    "from reportlab.lib.pagesizes import landscape, A4\n",
    "\n",
    "target_event = \"SOL20121127\"  # 🔹 will only plot this event\n",
    "plot_dir = r'C:\\Data\\Project\\outputs\\combined_plots'\n",
    "os.makedirs(plot_dir, exist_ok=True)\n",
    "output_pdf_path = os.path.join(plot_dir, f\"{target_event}_plot.pdf\")\n",
    "\n",
    "for index, row in df.iterrows():\n",
    "    if str(row['SOL FORMAT']).strip() != target_event:\n",
    "        continue  # process only the matching event\n",
    "\n",
    "    try:\n",
    "        # --- BASIC INFO ---\n",
    "        date_str = convert_date(row['Original date'])\n",
    "        if date_str is None:\n",
    "            continue\n",
    "        sol_format = row['SOL FORMAT']\n",
    "        start_time_str = row['Start (goes)']\n",
    "        end_time_str = row['End']\n",
    "        peak_time_str = row['Peak,']\n",
    "        goes_class = row['GOES Class']\n",
    "        gbm_det = row['first det']\n",
    "\n",
    "        start_time = int(start_time_str.split(':')[0]) * 3600 + int(start_time_str.split(':')[1]) * 60\n",
    "        end_time = int(end_time_str.split(':')[0]) * 3600 + int(end_time_str.split(':')[1]) * 60\n",
    "        peak_time = int(peak_time_str.split(':')[0]) * 3600 + int(peak_time_str.split(':')[1]) * 60\n",
    "\n",
    "        # --- FILE PATHS ---\n",
    "        year, month, day = date_str.split(\"-\")\n",
    "        year_last_two = year[2:]\n",
    "        file_versions = [\"v03\", \"v02\", \"v01\", \"v00\"]\n",
    "\n",
    "        gbm_file = None\n",
    "        for version in file_versions:\n",
    "            path = os.path.join(gbm_dir, f\"glg_ctime_{gbm_det}_{year_last_two}{month}{day}_{version}.pha\")\n",
    "            if os.path.exists(path):\n",
    "                gbm_file = path\n",
    "                break\n",
    "\n",
    "        goes_file = None\n",
    "        for n in [\"14\", \"15\"]:\n",
    "            path = os.path.join(goes_dir, f\"go{n}{year}{month}{day}.fits\")\n",
    "            if os.path.exists(path):\n",
    "                goes_file = path\n",
    "                break\n",
    "\n",
    "        lat_file = os.path.join(lat_dir, f\"lat_LC_{year}{month}{day}.fits\")\n",
    "\n",
    "        # --- VISUAL SETTINGS ---\n",
    "        import matplotlib.pyplot as plt\n",
    "        plt.rcParams.update({'font.size': 18, 'axes.labelsize': 18, 'axes.titlesize': 18})\n",
    "        fig, axs = plt.subplots(4, 1, figsize=(16, 20), sharex=True)\n",
    "        fig.suptitle(f'{sol_format} - {goes_class}', fontsize=18, y=0.95)\n",
    "        # 16,18 provides a good fit \n",
    "\n",
    "        xmin = (start_time - 3600) / 3600.0\n",
    "        xmax = (end_time + 3600) / 3600.0\n",
    "        start_time_hours = start_time / 3600.0\n",
    "        end_time_hours = end_time / 3600.0\n",
    "        peak_time_hours = peak_time / 3600.0\n",
    "\n",
    "        # --- PLOTS ---\n",
    "        if gbm_file:\n",
    "            plot_light_curve_gbm(axs[0], gbm_file, start_time_hours, end_time_hours, peak_time_hours, gbm_det, start_time_str, end_time_str)\n",
    "        else:\n",
    "            axs[0].text(0.5, 0.5, 'GBM data not available', ha='center', va='center', fontsize=12)\n",
    "\n",
    "        if goes_file:\n",
    "            plot_light_curve_goes(axs[1], goes_file, start_time_hours, end_time_hours, peak_time_hours, start_time_str, end_time_str)\n",
    "            plot_light_curve_derivative(axs[2], goes_file, start_time_hours, end_time_hours, peak_time_hours, start_time_str, end_time_str)\n",
    "        else:\n",
    "            axs[1].text(0.5, 0.5, 'GOES data not available', ha='center', va='center', fontsize=12)\n",
    "            axs[2].text(0.5, 0.5, 'GOES derivative data not available', ha='center', va='center', fontsize=12)\n",
    "\n",
    "        if os.path.exists(lat_file):\n",
    "            plot_light_curve_lat(axs[3], lat_file, start_time_hours, end_time_hours, peak_time_hours, start_time_str, end_time_str)\n",
    "        else:\n",
    "            axs[3].text(0.5, 0.5, 'LAT data not available', ha='center', va='center', fontsize=12)\n",
    "\n",
    "        for ax in axs:\n",
    "            ax.set_xlim(xmin, xmax)\n",
    "            ax.axvline(peak_time_hours, color='r', linestyle='--')\n",
    "            ax.grid(True)\n",
    "\n",
    "        axs[-1].set_xlabel('Time [hours]', fontsize=18)\n",
    "        plt.subplots_adjust(hspace=0.11)\n",
    "\n",
    "        plt.tight_layout(rect=[0, 0.03, 1, 0.93])\n",
    "        \n",
    "\n",
    "        # --- SAVE PNG ---\n",
    "        png_path = os.path.join(plot_dir, f\"{sol_format}_{goes_class}.png\")\n",
    "        plt.savefig(png_path, dpi=300, bbox_inches='tight')\n",
    "        plt.close()\n",
    "\n",
    "        # --- CREATE PDF ---\n",
    "        c = canvas.Canvas(output_pdf_path, pagesize=landscape(A4))\n",
    "        img = Image.open(png_path)\n",
    "        img_width, img_height = img.size\n",
    "        page_width, page_height = landscape(A4)\n",
    "\n",
    "        scale = min(page_width / img_width, page_height / img_height) * 0.95\n",
    "        new_width = img_width * scale\n",
    "        new_height = img_height * scale\n",
    "        x = (page_width - new_width) / 2\n",
    "        y = (page_height - new_height) / 2\n",
    "\n",
    "        c.drawImage(png_path, x, y, new_width, new_height)\n",
    "        c.save()\n",
    "\n",
    "        print(f\"✅ {sol_format} saved: {output_pdf_path}\")\n",
    "        break  # plot only the target_event\n",
    "\n",
    "    except Exception as e:\n",
    "        print(f\"Error processing {target_event}: {e}\")\n",
    "\n",
    "    \n",
    "   ]\n",
    "  },\n",
